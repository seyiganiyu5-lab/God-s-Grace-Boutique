# ─── Local Development (SQLite) ───
# DATABASE_URL=file:./dev.db

# ─── Production / Vercel (Neon PostgreSQL) ───
# Get this from: https://console.neon.tech → Copy connection string
# DATABASE_URL=postgresql://username:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ─── Auth ───
JWT_SECRET=your-secret-key-here

# ─── Vercel Blob (for image uploads on Vercel) ───
# Get this from: https://vercel.com/dashboard → Project → Storage → Blob → Copy token
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
